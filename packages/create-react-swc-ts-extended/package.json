{
  "name": "create-react-swc-ts-extended",
  "version": "1.0.1",
  "description": "CLI to create a React boilerplate with Vite + SWC, React 19, TypeScript, Vitest, Testing Library, TailwindCSS 4, Eslint and Prettier, Husky and lint-staged",
  "type": "module",
  "bin": {
    "create-react-swc-ts-extended": "dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "local-test": "./test-cli.sh",
    "package-test": "./test-package.sh",
    "pre-commit": "pnpm exec lint-staged -c ./.lintstagedrc.mjs --concurrent false"
  },
  "keywords": [
    "cli",
    "react",
    "vite",
    "swc",
    "typescript",
    "tailwindcss",
    "template"
  ],
  "author": {
    "email": "caymo.abesuni@gmail.com",
    "name": "Abe Suni M. Caymo",
    "url": "https://github.com/abetoots"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "chalk": "^5.3.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "minimist": "^1.2.8",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@satoshibits/eslint-config": "^2.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.6.2",
    "@typescript-eslint/utils": "^8.59.3",
    "@vitest/ui": "4.0.18",
    "eslint": "^9.12.0",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.4",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
